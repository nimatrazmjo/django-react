# .env.staging
DJANGO_SETTINGS_MODULE=config.settings.staging
DJANGO_SECRET_KEY=${DJANGO_SECRET_KEY}      # injected by CI
DEBUG=False
ALLOWED_HOSTS=staging.myapp.com
DATABASE_URL=${DATABASE_URL}                # injected by CI
REDIS_URL=${REDIS_URL}
CORS_ALLOWED_ORIGINS=https://staging.myapp.com

VITE_API_URL=https://staging.myapp.com
VITE_ENV=staging